digraph G {

graph [bgcolor="white", pad="0.35", nodesep="0.42", ranksep="0.65", fontname="DejaVu Sans", fontsize=18, labelloc=t, labeljust=l, compound=true, splines=ortho];
node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=11, color="#334155", penwidth=1.3, fillcolor="#F8FAFC", fontcolor="#0F172A", margin="0.16,0.10"];
edge [fontname="DejaVu Sans", fontsize=9, color="#64748B", fontcolor="#334155", penwidth=1.3, arrowsize=0.75];

label="Runtime Request and Asynchronous Workflow";
rankdir=LR;
node [width=2.0];
request [label="1. Authenticated Request
Idempotency-Key + Correlation ID", fillcolor="#E0F2FE"];
routing [label="2. Route 53 Selects
Healthy Active Site", fillcolor="#FEF3C7"];
api [label="3. Regional API
Validates JWT + Context"];
txn [label="4. DynamoDB Transaction
Workflow + Deterministic Outbox
ownerRegion recorded", fillcolor="#F3E8FF"];
accepted [label="5. 202 Accepted
Stable work identifier", fillcolor="#DCFCE7"];
pub [label="6. Scheduled Publisher
Claims pending outbox"];
queue [label="7. Owner-Region SQS
Durable transport"];
worker [label="8. Worker
Validates ownership + state
Claims lease"];
result [label="9. Terminal / Retryable State
Result visible from either site", fillcolor="#DCFCE7"];
request -> routing -> api -> txn;
txn -> accepted;
txn -> pub [label="PENDING"];
pub -> queue [label="publish"];
pub -> txn [label="mark delivered", constraint=false];
queue -> worker [label="at-least-once delivery"];
worker -> result [label="conditional state transition"];
result -> request [label="poll / cross-region read", style=dashed, constraint=false];
}