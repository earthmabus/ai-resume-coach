# Terraform local/cache files
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
*.tfvars
!*.tfvars.example

# Terraform generated artifacts
*.zip
infra/lambda.zip
infra/pdf_layer.zip
infra/worker.zip
lambda_layer/build

# Terraform saved plan files
infra/tfplan*
*.tfplan

# source files

# temporarily generated build directory
build/*
debug/*

# Local runtime-validation evidence
evidence/
tools/validate/*.env

# Python caches and tooling
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Python virtual environments
.venv/
venv/

# Node dependencies and generated synthetic assets
**/node_modules/

# Local build and runtime output
**/.terraform-build/
build/
dist/
*.log

# IDE and operating-system files
.vscode/
.idea/
.DS_Store

# Repository-owned Python build tooling must remain version controlled.
# These exceptions must appear after the generic build/ ignore rules above.
!tools/build/
!tools/build/**

# Python bytecode
__pycache__/
*.py[cod]
